rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "kuteyioluwaloyevincent291@gmail.com" && 
             request.auth.token.email_verified == true;
    }
    match /bookings/{bookingId} {
      allow create: if request.resource.data.keys().hasAll(['service', 'date', 'time', 'address', 'name', 'phone', 'status', 'createdAt']);
      allow read, update, delete: if isAdmin();
    }
  }
}
